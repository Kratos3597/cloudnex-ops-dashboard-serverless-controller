{
  "name": "CloudNex Dashboard",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/android:1": {
      "commandLineTools": "latest",
      "platformTools": "latest",
      "emulator": "false" 
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "flutter.sdkPath": "/usr/local/flutter"
      }
    }
  },
  "mounts": [
    "source=android-sdk,target=/home/vscode/Android/Sdk,type=volume"
  ]
}